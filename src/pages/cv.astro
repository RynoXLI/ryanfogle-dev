---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const cvEntry = await getEntry('cv', 'cv');
const cv = cvEntry?.data;

function formatDate(value: string | null | undefined) {
	if (!value) return 'Present';
	return new Date(value).toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		timeZone: 'UTC',
	});
}
---

<Layout title={`CV — ${cv?.name ?? 'Ryan Fogle'}`}>
	<Nav slot="nav" />

	{
		cv ? (
			<article class="space-y-12">
				<header class="space-y-3 border-b border-stone-200 pb-8 dark:border-stone-800">
					<h1 class="font-serif text-4xl font-bold tracking-tight">{cv.name}</h1>
					<p class="text-lg text-stone-600 dark:text-stone-300">{cv.headline}</p>
					<p class="text-sm text-stone-500 dark:text-stone-400">
						{cv.location} · {cv.email}
					</p>
					{cv.links.length > 0 && (
						<ul class="flex gap-5 text-sm">
							{cv.links.map((link) => (
								<li>
									<a class="font-medium text-accent hover:underline" href={link.url}>
										{link.label}
									</a>
								</li>
							))}
						</ul>
					)}
				</header>

				{cv.summary && (
					<section>
						<p class="text-lg leading-relaxed text-stone-700 dark:text-stone-200">{cv.summary}</p>
					</section>
				)}

				{cv.skills.length > 0 && (
					<section class="space-y-3">
						<h2 class="font-serif text-2xl font-semibold">Skills</h2>
						<ul class="flex flex-wrap gap-2">
							{cv.skills.map((skill) => (
								<li class="rounded-full border border-stone-200 px-3 py-1 text-sm text-stone-700 dark:border-stone-700 dark:text-stone-200">
									{skill}
								</li>
							))}
						</ul>
					</section>
				)}

				{cv.experience.length > 0 && (
					<section class="space-y-3">
						<h2 class="font-serif text-2xl font-semibold">Experience</h2>
						<div class="divide-y divide-stone-200 dark:divide-stone-800">
							{cv.experience.map((job) => (
								<div class="py-6 first:pt-0">
									<div class="flex flex-wrap items-baseline justify-between gap-x-4">
										<h3 class="font-medium">
											{job.role} · {job.company}
										</h3>
										<span class="shrink-0 text-sm text-stone-500 dark:text-stone-400">
											{formatDate(job.startDate)} – {formatDate(job.endDate)}
										</span>
									</div>
									{job.description.length > 0 && (
										<ul class="mt-2 list-disc space-y-1.5 pl-5 text-stone-700 dark:text-stone-200">
											{job.description.map((bullet) => (
												<li>{bullet}</li>
											))}
										</ul>
									)}
								</div>
							))}
						</div>
					</section>
				)}

				{cv.education.length > 0 && (
					<section class="space-y-3">
						<h2 class="font-serif text-2xl font-semibold">Education</h2>
						<div class="divide-y divide-stone-200 dark:divide-stone-800">
							{cv.education.map((edu) => (
								<div class="flex flex-wrap items-baseline justify-between gap-x-4 py-4 first:pt-0">
									<h3 class="font-medium">
										{edu.degree} · {edu.school}
									</h3>
									{(edu.startDate || edu.endDate) && (
										<span class="text-sm text-stone-500 dark:text-stone-400">
											{formatDate(edu.startDate)} – {formatDate(edu.endDate)}
										</span>
									)}
								</div>
							))}
						</div>
					</section>
				)}
			</article>
		) : (
			<p>
				No CV data yet. Add one at <code>/keystatic</code>.
			</p>
		)
	}
</Layout>
