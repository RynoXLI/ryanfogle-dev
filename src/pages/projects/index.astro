---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

const projects = await getCollection('projects');
const sorted = [...projects].sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
---

<Layout title="Projects">
	<Nav slot="nav" />

	<h1 class="mb-10 font-serif text-4xl font-bold tracking-tight">Projects</h1>

	<ul class="divide-y divide-stone-200 dark:divide-stone-800">
		{
			sorted.map((project) => (
				<li class="py-8 first:pt-0">
					<a
						href={`/projects/${project.id}`}
						class="font-serif text-2xl font-semibold transition-colors hover:text-accent"
					>
						{project.data.title}
					</a>
					<p class="mt-3 leading-relaxed text-stone-600 dark:text-stone-300">{project.data.description}</p>
					{project.data.tags.length > 0 && (
						<ul class="mt-4 flex flex-wrap gap-2">
							{project.data.tags.map((tag) => (
								<li class="rounded-full border border-stone-200 px-3 py-1 text-xs text-stone-600 dark:border-stone-700 dark:text-stone-300">
									{tag}
								</li>
							))}
						</ul>
					)}
				</li>
			))
		}
	</ul>

	{projects.length === 0 && <p>No projects yet. Add one at <code>/keystatic</code>.</p>}
</Layout>
