---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf()
);
---

<Layout title="Blog">
	<Nav slot="nav" />

	<h1 class="mb-10 font-serif text-4xl font-bold tracking-tight">Blog</h1>

	<ul class="divide-y divide-stone-200 dark:divide-stone-800">
		{
			posts.map((post) => (
				<li class="py-8 first:pt-0">
					<a href={`/blog/${post.id}`} class="font-serif text-2xl font-semibold transition-colors hover:text-accent">
						{post.data.title}
					</a>
					<p class="mt-2 text-xs font-medium tracking-wide text-stone-500 uppercase dark:text-stone-400">
						{post.data.publishedDate.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</p>
					<p class="mt-3 leading-relaxed text-stone-600 dark:text-stone-300">{post.data.description}</p>
				</li>
			))
		}
	</ul>

	{posts.length === 0 && <p>No posts yet. Add one at <code>/keystatic</code>.</p>}
</Layout>
