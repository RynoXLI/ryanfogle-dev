---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

const entries = (await getCollection('work')).sort(
	(a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf()
);
---

<Layout title="Work">
	<Nav slot="nav" />

	<ul class="divide-y divide-stone-200 dark:divide-stone-800">
		{
			entries.map((entry) => (
				<li class="py-8 first:pt-0">
					<a href={`/work/${entry.id}`} class="font-serif text-2xl font-semibold transition-colors hover:text-accent">
						{entry.data.title}
					</a>
					<p class="mt-2 text-xs font-medium tracking-wide text-stone-500 uppercase dark:text-stone-400">
						{entry.data.publishedDate.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</p>
					<p class="mt-3 leading-relaxed text-stone-600 dark:text-stone-300">{entry.data.description}</p>
					{entry.data.tags.length > 0 && (
						<ul class="mt-4 flex flex-wrap gap-2">
							{entry.data.tags.map((tag) => (
								<li class="rounded-full border border-stone-200 px-3 py-1 text-xs text-stone-600 dark:border-stone-700 dark:text-stone-300">
									{tag}
								</li>
							))}
						</ul>
					)}
				</li>
			))
		}
	</ul>
	{entries.length === 0 && <p>Nothing here yet. Add one at <code>/admin</code>.</p>}
</Layout>
