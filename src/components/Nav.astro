---
import { getEntry } from 'astro:content';

const settingsEntry = await getEntry('settings', 'settings');
const settings = settingsEntry?.data;
const links = settings?.navLinks ?? [
	{ href: '/', label: 'Home' },
	{ href: '/cv', label: 'CV' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/projects', label: 'Projects' },
];
const siteName = settings?.siteName ?? 'Ryan Fogle';

const currentPath = Astro.url.pathname;
---

<nav class="flex flex-wrap items-center justify-between gap-4 border-b border-stone-200 py-6 dark:border-stone-800">
	<a href="/" class="font-serif text-xl font-semibold tracking-tight text-stone-900 dark:text-stone-100">
		{siteName}
	</a>
	<ul class="flex gap-6">
		{
			links.map((link) => {
				const isActive = link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href);
				return (
					<li>
						<a
							href={link.href}
							class={`text-xs font-medium tracking-wide uppercase transition-colors hover:text-accent ${
								isActive ? 'text-accent' : 'text-stone-500 dark:text-stone-400'
							}`}
						>
							{link.label}
						</a>
					</li>
				);
			})
		}
	</ul>
</nav>
